# Project Configuration
LOG_LEVEL=INFO
DEMO_TYPE=telco # Oneof: retail, telco, software, gaming, campaign_designer

# Google Cloud Configuration (API endpoint)
GOOGLE_GENAI_USE_VERTEXAI=0             # Set to 1 to use Vertex AI endpoint

# API Configuration
GOOGLE_API_KEY=your_google_api_key      # Required for Dev endpoint (i.e. GOOGLE_GENAI_USE_VERTEXAI=0)

# Vertex - Project Configuration
GOOGLE_CLOUD_PROJECT=your_project_id    # Required for Vertex endpoint (i.e. GOOGLE_GENAI_USE_VERTEXAI=1)
GOOGLE_CLOUD_LOCATION=your_region       # Required for Vertex endpoint (i.e. GOOGLE_GENAI_USE_VERTEXAI=1)


# Data Science Agent 
BQ_PROJECT_ID=your-bq-project-id
BQ_DATASET_ID=your-bq-dataset-id

BQML_RAG_PROJECT_ID= your-bqml-project-id

CODE_INTERPRETER_EXTENSION_NAME=your-existing-codeinterpreter  # 'projects/{project-number}/locations/us-central1/extensions/{extension-ID}'
BQML_RAG_CORPUS_NAME=your-bqml-rag-corpus-name                 # 'projects/{project-number}/locations/us-central1/ragCorpora/{rag-corpus-ID}'

USE_CODE_INTERPRETER_ENV=0 # 1 for enabling the extention and executing code and 0 for not

# Live Agent Voice
VOICE_DEV_API=Puck
VOICE_VERTEX_API=Aoede
#Available Voices
#Aoede (Female), Puck (Male), Charon (Male), Kore (Female), Fenrir (Male), Leda (Female), Orus (Male), Zephyr (Female)

# Live Agent Language
LANGUAGE="en-GB"
# Available languages 
#"de-DE":"German", "en-AU": "English (Australia)", "en-GB": "English (United Kingdom)", "en-IN": "English (India)", 
#"es-US": "Spanish (United States)", "fr-FR": "French (France)",	"hi-IN": "Hindi (India)", "pt-BR": "Portuguese (Brazil)", 
#"ar-XA": "Arabic (Generic)", "es-ES": "Spanish (Spain)", "fr-CA": "French (Canada)", "id-ID": "Indonesian (Indonesia)",	
#"it-IT": "Italian (Italy)", "ja-JP": "Japanese (Japan)", "tr-TR": "Turkish (Turkey)", "vi-VN": "Vietnamese (Vietnam)",
#"bn-IN": "Bengali (India)", "gu-IN": "Gujarati (India)", "kn-IN": "Kannada (India)", "ml-IN": "Malayalam (India)",
#"mr-IN": "Marathi (India)", "ta-IN": "Tamil (India)", "te-IN": "Telugu (India)","nl-NL": "Dutch (Netherlands)",
#"ko-KR": "Korean (South Korea)", "cmn-CN": "Mandarin Chinese (China)", "pl-PL": "Polish (Poland)", "ru-RU": "Russian (Russia)",
