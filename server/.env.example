# Project Configuration
LOG_LEVEL=INFO
DEMO_TYPE=retail                        # Oneof: retail, telco, software, gaming, campaign_designer

# ===== Backend Selection =====
# The system automatically detects which backend to use:
# - If GOOGLE_API_KEY is available: Uses AI Studio with Gemini 3.1 model
# - If GOOGLE_API_KEY is NOT available: Uses Vertex AI with Gemini 2.5 model
#
# NOTE: As of March 2026, gemini-3.1-flash-live-preview is not yet fully supported by ADK
# due to API changes in how it handles real-time input. Using Vertex AI is recommended.
#
# You can override this auto-detection by explicitly setting GOOGLE_GENAI_USE_VERTEXAI:
# - Set to 0 to force AI Studio (may have compatibility issues with ADK)
# - Set to 1 to force Vertex AI (recommended for production)
# - Leave unset (commented out) for auto-detection
GOOGLE_GENAI_USE_VERTEXAI=1

# ===== OPTION 1: AI Studio (Recommended for Development) =====
# Get your API key from: https://aistudio.google.com/apikey
# IMPORTANT: Comment out GOOGLE_API_KEY when using Vertex AI (GOOGLE_GENAI_USE_VERTEXAI=1)
# GOOGLE_API_KEY=your_google_api_key_from_ai_studio

# Model for AI Studio (default: gemini-3.1-flash-live-preview)
MODEL_DEV_API=gemini-3.1-flash-live-preview
AGENT_MODEL_DEV_API=gemini-3.1-flash-live-preview

# ===== OPTION 2: Vertex AI (Recommended for Production) =====
# Vertex AI Project Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model for Vertex AI (default: gemini-live-2.5-flash-native-audio)
# MODEL_VERTEX_API=gemini-live-2.5-flash-native-audio
# AGENT_MODEL_VERTEX_API=gemini-live-2.5-flash-native-audio


# Data Science Agent 
BQ_PROJECT_ID=your-bq-project-id
BQ_DATASET_ID=your-bq-dataset-id

BQML_RAG_PROJECT_ID= your-bqml-project-id

CODE_INTERPRETER_EXTENSION_NAME=your-existing-codeinterpreter  # 'projects/{project-number}/locations/us-central1/extensions/{extension-ID}'
BQML_RAG_CORPUS_NAME=your-bqml-rag-corpus-name                 # 'projects/{project-number}/locations/us-central1/ragCorpora/{rag-corpus-ID}'

USE_CODE_INTERPRETER_ENV=0 # 1 for enabling the extention and executing code and 0 for not

# Live Agent Voice
VOICE_DEV_API=Puck
VOICE_VERTEX_API=Aoede
#Available Voices
#Aoede (Female), Puck (Male), Charon (Male), Kore (Female), Fenrir (Male), Leda (Female), Orus (Male), Zephyr (Female)

# Live Agent Language
LANGUAGE="en-GB"

# Image API Keys (for home decor product images)
# Google Custom Search API (Recommended - uses your existing Google Cloud project)
# 1. Enable Custom Search API: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
# 2. Create a Programmable Search Engine: https://programmablesearchengine.google.com/
# 3. Get your Search Engine ID (cx parameter)
# Note: GOOGLE_API_KEY may already be set above for AI Studio
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Optional: Unsplash API as fallback
# Get your API key from: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
# Available languages 
#"de-DE":"German", "en-AU": "English (Australia)", "en-GB": "English (United Kingdom)", "en-IN": "English (India)", 
#"es-US": "Spanish (United States)", "fr-FR": "French (France)",	"hi-IN": "Hindi (India)", "pt-BR": "Portuguese (Brazil)", 
#"ar-XA": "Arabic (Generic)", "es-ES": "Spanish (Spain)", "fr-CA": "French (Canada)", "id-ID": "Indonesian (Indonesia)",	
#"it-IT": "Italian (Italy)", "ja-JP": "Japanese (Japan)", "tr-TR": "Turkish (Turkey)", "vi-VN": "Vietnamese (Vietnam)",
#"bn-IN": "Bengali (India)", "gu-IN": "Gujarati (India)", "kn-IN": "Kannada (India)", "ml-IN": "Malayalam (India)",
#"mr-IN": "Marathi (India)", "ta-IN": "Tamil (India)", "te-IN": "Telugu (India)","nl-NL": "Dutch (Netherlands)",
#"ko-KR": "Korean (South Korea)", "cmn-CN": "Mandarin Chinese (China)", "pl-PL": "Polish (Poland)", "ru-RU": "Russian (Russia)",
#"th-TH": "Thai (Thailand)"