
# Demo Configuration
LOG_LEVEL=INFO
# Oneof: retail, telco, software, gaming, campaign_designer
DEMO_TYPE=retail

# API Configuration
# Set to 1 to use Vertex AI endpoint
GOOGLE_GENAI_USE_VERTEXAI=1

# API Configuration
#GOOGLE_API_KEY=your_google_api_key # Set if GOOGLE_GENAI_USE_VERTEXAI=0

# Project Configuration
